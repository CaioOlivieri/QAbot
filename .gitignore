# =============================================================================
# SEGURANÇA — jamais remover estas linhas
# =============================================================================
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx
secrets/
credentials/

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
MANIFEST

# =============================================================================
# Ambientes virtuais
# =============================================================================
.venv/
venv/
env/
ENV/
.python-version

# =============================================================================
# uv
# =============================================================================
# manter uv.lock no git (reprodutibilidade)
.uv/

# =============================================================================
# Testes e cobertura
# =============================================================================
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
*.log

# =============================================================================
# qabot — outputs gerados pelo agente
# =============================================================================
# reports/* (e não reports/): o git não re-inclui o filho de um DIRETÓRIO
# excluído, então a exceção abaixo exige ignorar o conteúdo, não o diretório.
# O ledger é versionado de propósito: o job noturno (qa-gate.yml) commita o
# trend de defeitos de volta ao main — ele contém apenas metadados de achados,
# nunca segredos.
reports/*
!reports/qabot_state.json

# =============================================================================
# IDEs
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# =============================================================================
# Cursor
# =============================================================================
.cursor/rules
# manter .cursor/settings.json se quiser compartilhar configurações de time
.env.keys
