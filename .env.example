# Copy this file to .env.keys and fill in your key.
# Get a key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: override the Gemini model (default: gemini-2.5-flash-lite)
# QABOT_MODEL=gemini-2.5-flash

# Optional: enable outbound API endpoint testing (off by default)
# QABOT_ALLOW_NETWORK=1

# Optional: production reconciliation (DRE). Leave QABOT_PROD_REPO unset to disable.
# Repo whose GitHub issues are the production-bug source:
# QABOT_PROD_REPO=owner/repo
# Labels marking a production bug (default: bug,production):
# QABOT_PROD_LABELS=bug,production
# Labels marking a bug as critical (default: critical,blocker,p0,sev1):
# QABOT_CRITICAL_LABELS=critical,blocker,p0,sev1
# Read-only GitHub token (optional; public repos work without it, rate-limited):
# GITHUB_TOKEN=
# DRE window in days (default 90, per Capers Jones; ISBSG uses 30):
# QABOT_DRE_WINDOW_DAYS=90
